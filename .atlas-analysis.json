{
  "projectType": "saas",
  "projectName": "Stable Diffusion Web UI",
  "projectDescription": "A feature-rich web interface for Stable Diffusion AI image generation, supporting txt2img, img2img, inpainting, upscaling, extensions, and a REST API.",
  "theme": "palm",
  "primaryColor": "#7C3AED",
  "lightColor": "#EDE9FE",
  "darkColor": "#4C1D95",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Core Features",
            "pages": [
              "features/txt2img",
              "features/img2img",
              "features/inpainting",
              "features/upscaling",
              "features/extra-networks"
            ]
          },
          {
