            "pages": [
              "configuration/command-line-args",
              "configuration/settings",
              "configuration/optimizations"
            ]
          },
          {
            "group": "Extensions",
            "pages": [
              "extensions/overview",
              "extensions/installing",
              "extensions/developing"
            ]
          },
          {
            "group": "Training",
            "pages": [
              "training/textual-inversion",
              "training/hypernetworks"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
